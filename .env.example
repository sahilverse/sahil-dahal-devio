# ==============================================================================
# DEVIO MASTER ENVIRONMENT TEMPLATE (.env.example)
# ==============================================================================
# Use this as a template for your .env.local (Dev) or .env.prod (Production).
# Copy this file to .env.local and fill in the values below.

# --- GLOBAL ---
NODE_ENV=development
LOG_LEVEL=info
COMPOSE_PROJECT_NAME=devio
DOCKER_NETWORK=devio-network

# --- PORT CONFIGURATION ---
PORT_BACKEND=8000
PORT_FRONTEND=3000
PORT_CODE_SANDBOX=5000
PORT_LAB_ORCHESTRATOR=5500

# --- INFRASTRUCTURE ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=devio_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

REDIS_URL=redis://redis:6379

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

MINIO_ENDPOINT=http://localhost:9000
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

S3_REGION=ap-south-1

MINIO_BUCKET_UPLOADS=devio-uploads
MINIO_BUCKET_PROBLEMS=devio-problems
MINIO_BUCKET_LABS=devio-labs
MINIO_BUCKET_VIDEOS=devio-videos

# --- AUTH (JWT & OAUTH) ---
JWT_ACCESS_SECRET=your_jwt_access_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

JWT_RESET_PASSWORD_SECRET=your_reset_secret
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_EMAIL_VERIFICATION_SECRET=your_verification_secret
JWT_EMAIL_VERIFICATION_EXPIRATION_MINUTES=10

# OAuth 
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:${PORT_FRONTEND}/auth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:${PORT_FRONTEND}/auth/github/callback

# --- SMTP (Email) ---
SMTP_EMAIL_USER=your_email@gmail.com
SMTP_EMAIL_PASS=your_app_password

# --- PAYMENTS (eSewa) ---
ESEWA_SECRET_KEY=your_esewa_secret
ESEWA_PRODUCT_CODE=your_product_code
ESEWA_GATEWAY_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form

# --- FRONTEND  ---
NEXT_PUBLIC_API_URL=http://localhost:${PORT_BACKEND}/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:${PORT_BACKEND}
NEXT_PUBLIC_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
NEXT_PUBLIC_GITHUB_CLIENT_ID=${GITHUB_CLIENT_ID}

# -- SERVICES --
CODE_SANDBOX_URL=http://devio-code-sandbox:${PORT_CODE_SANDBOX}/api
LAB_ORCHESTRATOR_URL=http://devio-lab-orchestrator:${PORT_LAB_ORCHESTRATOR}
JUDGE0_URL=http://your_judge0_ip_or_service:2358

# --- JUDGE0 STACK SECRETS ---  NOT USED IN DEV -- (SEPARATE CONTAINER DURING DEVELOPMENT)
JUDGE0_REDIS_PASSWORD=password
JUDGE0_DB_PASSWORD=password
JUDGE0_DB_USER=judge0
JUDGE0_DB_NAME=judge0

# --- DOCKER / SYSTEM ---
DOCKER_SOCKET_PATH=/var/run/docker.sock


# --- Transcoder --
FFMPEG_PATH=ffmpeg
DISABLE_GPU=true


# --- PLATFORM ADMIN --
ADMIN_EMAIL=admin@devio.com
ADMIN_PASSWORD=S@@hil-123